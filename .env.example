# OpenRouter API key — https://openrouter.ai/
# Copy this file to `.env` and paste your key. Restart `npm run dev` after changing.
# GitHub deploy: add repository secret VITE_OPENROUTER_API_KEY (never paste keys here).
# Any VITE_* value is embedded in client JS; for a non-exposed key, use a backend proxy.
VITE_OPENROUTER_API_KEY=

# Optional: wayfinding image (you must have rights to the map).
# Either add a file at public/museum-map.png or set a URL:
# VITE_MUSEUM_MAP_URL=/museum-map.png
