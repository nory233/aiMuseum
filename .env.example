# OpenRouter — https://openrouter.ai/keys
# Copy this file to `.env` for local dev; restart `npm run dev` after edits.
#
# Recommended for a public repo: deploy `cloudflare-worker/` and set only the gateway URL below.
# The real API key lives in Cloudflare (`wrangler secret put OPENROUTER_API_KEY`), not in GitHub.

# HTTPS URL of your OpenRouter proxy worker (no trailing slash). Safe to commit or use as a GitHub Actions variable.
VITE_OPENROUTER_GATEWAY_URL=

# Optional local dev / private forks: direct key in bundle (never commit real values; CI strips this on Pages build).
VITE_OPENROUTER_API_KEY=

# Optional floor map: leave unset to use public/museum-map.svg (committed placeholder).
# Or set full URL (https://.../plan.png), or filename only placed in public/ (e.g. stadsmuseet-map.png).
# VITE_MUSEUM_MAP_URL=

# Optional immersive backdrop when there is NO scan image: muted MP4 in public/ or full https URL.
# Leave unset for a neutral CSS gallery gradient (no stock clip). Not used when the user has a scan capture.
# VITE_IMMERSIVE_AMBIENT_URL=immersive-ambient.mp4
